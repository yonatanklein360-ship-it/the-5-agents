# ==============================================================================
# the-5-agents — Environment Variables (template)
# ------------------------------------------------------------------------------
# העתק קובץ זה ל-.env ומלא ערכים אמיתיים:  cp .env.example .env
# קובץ .env מוחרג מ-git ולעולם לא נדחף — אל תכניס כאן מפתחות אמיתיים.
# ==============================================================================

# --- ליבה: ראובן והצוות (Claude) -------------------------------------------
# מפתח ה-API של Anthropic, משמש את כל הסוכנים מבוססי Claude.
ANTHROPIC_API_KEY=

# --- חן (חוקרת) — חיפוש/מחקר באינטרנט --------------------------------------
# בחר ספק חיפוש אחד (אופציונלי, לפי הצורך בשלב המחקר).
TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=
# SERPER_API_KEY=

# --- יובל (מעצב תמונות) — יצירת תמונות -------------------------------------
# בחר ספק יצירת תמונות אחד (אופציונלי).
OPENAI_API_KEY=
# STABILITY_API_KEY=

# --- הגדרות כלליות (אופציונלי) ---------------------------------------------
# סביבת הרצה: development | production
NODE_ENV=development
# רמת לוגים: debug | info | warn | error
LOG_LEVEL=info
